# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.

# -------------------------------------------------------------------
# App
# -------------------------------------------------------------------

# The public URL of the app (used for redirects, OAuth callbacks, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------------------------------------------------------------------
# Database
# -------------------------------------------------------------------

# Neon serverless Postgres connection string.
# Get it from: https://console.neon.tech → your project → Connection string
# Make sure to use the pooled connection URL (includes "-pooler" in the host).
DATABASE_URL=""

# -------------------------------------------------------------------
# Auth (Auth.js)
# -------------------------------------------------------------------

# Secret used to sign session tokens. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth credentials.
# Create an OAuth 2.0 client at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# -------------------------------------------------------------------
# Email (Resend)
# -------------------------------------------------------------------

# Resend API key for sending transactional emails.
# Get it from: https://resend.com/api-keys
RESEND_API_KEY=""

# -------------------------------------------------------------------
# Seeding (optional)
# -------------------------------------------------------------------

# The user ID to seed data for. Run the app, sign in, then find your
# user ID in Drizzle Studio (npm run db:studio) or the database directly.
SEED_USER_ID=""
